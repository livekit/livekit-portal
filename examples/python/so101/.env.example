# Copy to .env (or .env.local) and fill in.
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Shared session/room name. Robot and operator must agree.
LIVEKIT_ROOM=so101-portal

# Streaming rate.
PORTAL_FPS=30

# --- Robot side (so101 follower) ----------------------------------------
# Serial port for the SO-101 follower arm.
SO101_FOLLOWER_PORT=/dev/tty.usbmodem58CD1772311
# Calibration id; must match `--robot.id` you passed to `lerobot-calibrate`.
SO101_FOLLOWER_ID=so101_follower

# Camera (one OpenCV device).
SO101_CAMERA_NAME=front
SO101_CAMERA_INDEX=0
SO101_CAMERA_WIDTH=640
SO101_CAMERA_HEIGHT=480

# --- Operator side (so101 leader) ---------------------------------------
SO101_LEADER_PORT=/dev/tty.usbmodem58CD1772312
# Calibration id; must match `--teleop.id` you passed to `lerobot-calibrate`.
SO101_LEADER_ID=so101_leader
